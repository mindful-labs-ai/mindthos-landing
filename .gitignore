# ============================================================
# 이 저장소는 Vercel 배포 대상인 web/ 만 git 으로 추적한다.
# docs / scripts / blog-seo-template / .claude / global / ecosystem.config.js 등
# 배포와 무관한 파일은 로컬에만 두고 추적하지 않는다.
# 아래 whitelist 로 최상위(web/, .gitignore 제외) 전체를 무시한다.
# ============================================================
/*
!/.gitignore
!/web/

# ── 아래 규칙들은 web/ 내부에도 적용되는 세부 무시 항목 ──

# Environment variables
.env
.env.local
.env.*.local

# OS
.DS_Store
**/.DS_Store

# Dependencies
node_modules/

# Build output
dist/
build/
.next/
out/

# TypeScript build cache
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Blog auto-publish generated artifacts
scripts/publish-blog/content.json
scripts/publish-blog/daily-topics.json
scripts/publish-blog/seo-opportunities.json
scripts/publish-blog/seo-report.json
scripts/publish-blog/review-feedback.json
scripts/publish-blog/deleted-posts-backup.json
scripts/publish-blog/.data/

# R2 video migration artifacts (slug→URL 매핑 / video_url 백업)
scripts/.data/

# Syncthing artifacts
*.sync-conflict-*
.stfolder/
.stignore

# Python cache
__pycache__/
*.pyc

# OMC state (root + nested)
.omc/
**/.omc/

# Supabase CLI scratch (auto-generated by `supabase link`/`supabase db ...`)
supabase/.temp/
**/supabase/.temp/

# Claude Code local state
.claude/settings.local.json
**/.claude/settings.local.json
.claude/scheduled_tasks.lock
**/.claude/scheduled_tasks.lock

# QA artifacts (ephemeral — large screenshots and JSON dumps)
web/.qa/screenshots/
**/.qa/screenshots/
web/.qa/*-audit.json
**/.qa/*-audit.json

# Embedded sub-projects (have their own remote)
andotherlife-web/

# Global site (Modalia AI, modalia.ai) — separate project + planning workspace.
# KR 랜딩 저장소에 함께 두되 git 추적에서는 분리 (자체 remote/배포로 관리).
global/

# Internal design / planning workspace (not part of public landing)
mindthos-landing-design/

# IDE
.vscode/
.idea/
*.swp
*.swo
.vercel
