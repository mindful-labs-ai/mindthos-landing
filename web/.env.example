# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Management API (only for scripts/apply-supabase-migrations.sh)
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=

# Cloudflare R2 — 블로그 공개 미디어(동영상) 저장소.
# 개인별 bucket-scoped(mindthos-public-assets, Object Read & Write) S3 credential 만 사용.
# 실제 값은 커밋 금지 — .env.local 또는 password manager 에만 보관.
# 마이그레이션/업로드 스크립트(scripts/migrate-blog-videos-to-r2.mjs)가 이 변수들을 읽음.
# CF_MINDTHOS_PUBLIC_ASSETS_UPLOAD_ACCESS_KEY_ID=
# CF_MINDTHOS_PUBLIC_ASSETS_UPLOAD_SECRET_ACCESS_KEY=
# CF_MINDTHOS_PUBLIC_ASSETS_R2_ENDPOINT=https://5c024213396a3a0521c366fda67b55e4.r2.cloudflarestorage.com
# CF_MINDTHOS_PUBLIC_ASSETS_R2_REGION=auto
# CF_MINDTHOS_PUBLIC_ASSETS_R2_BUCKET=mindthos-public-assets
# CF_MINDTHOS_PUBLIC_ASSETS_PUBLIC_BASE_URL=https://media.mindthos.com

# Site
NEXT_PUBLIC_SITE_URL=https://mindthos.com
# Global site (Modalia AI) — used for blog hreflang reciprocity links. Optional; defaults to https://modalia.ai
NEXT_PUBLIC_GLOBAL_SITE_URL=https://modalia.ai
NEXT_PUBLIC_SITE_NAME=마음토스
NEXT_PUBLIC_SITE_EMAIL=
NEXT_PUBLIC_SITE_PHONE=

# Vercel ISR
REVALIDATION_SECRET=

# IndexNow (Bing/Yandex 즉시 인덱싱)
INDEXNOW_KEY=

# Slack notifications (academy inquiry alerts — Incoming Webhook URL)
SLACK_WEBHOOK_URL=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# Naver Webmaster/Ads 전환 추적 AccountId (비우면 layout 기본값 's_bfc366d6236' 사용)
NEXT_PUBLIC_NAVER_WCS_ID=

# Search engine / ad platform site verification (optional — empty = layout fallback 사용)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=

# Social channel overrides (optional — 비우면 SITE_CONFIG 기본값 사용)
NEXT_PUBLIC_INSTAGRAM=
NEXT_PUBLIC_THREADS=
NEXT_PUBLIC_LINKEDIN=
NEXT_PUBLIC_TWITTER=
