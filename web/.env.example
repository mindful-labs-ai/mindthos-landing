# Slack notifications (academy inquiry alerts — Incoming Webhook URL)
SLACK_WEBHOOK_URL=

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
# Naver Webmaster/Ads 전환 추적 AccountId (비우면 layout 기본값 's_bfc366d6236' 사용)
